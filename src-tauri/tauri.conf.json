{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "log-parser",
  "version": "0.1.1",
  "identifier": "com.logparser.app",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "log-parser — Excel log viewer",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "license": "Apache-2.0",
    "licenseFile": "../LICENSE",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../LICENSE": "legal/LICENSE",
      "../NOTICE": "legal/NOTICE",
      "resources/intel/mitre_core.v1.json": "intel/mitre_core.v1.json",
      "resources/models/qwen2.5-1.5b-instruct-q4_k_m.gguf": "models/qwen2.5-1.5b-instruct-q4_k_m.gguf",
      "resources/models/qwen2.5-1.5b-instruct-tokenizer.json": "models/qwen2.5-1.5b-instruct-tokenizer.json",
      "resources/models/all-minilm-l6-v2-model.safetensors": "models/all-minilm-l6-v2-model.safetensors",
      "resources/models/all-minilm-l6-v2-tokenizer.json": "models/all-minilm-l6-v2-tokenizer.json",
      "resources/models/all-minilm-l6-v2-config.json": "models/all-minilm-l6-v2-config.json"
    }
  }
}
